package com.kodewala;

import java.util.HashMap;
import java.util.Map;

public class SalaryCalculationTest {

    public Map<String, Object> calculateSalary(int salary) {

        Map<String, Object> map = new HashMap<>();

        if (salary < 5000) {
            map.put("ErrorCode", "Min Salary should be more than 5000");
        } 
        else if (salary > 10000) {
            int ctc = salary + (salary * 10 / 100);
            map.put("ctc", ctc);
        } 
        else {
            map.put("ctc", salary);
        }

        return map;
    }
}