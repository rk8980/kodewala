package com.kodewala.streamapipractice;

import java.util.Arrays;
import java.util.List;
import java.util.stream.Collectors;

public class Driver1 {

	public static void main(String[] args) {
		List<String> brand = Arrays.asList("samsung", "lg", "sony", "apple", "nokia"," micromax","realme");
		
		List<String> processBtrand =  brand.stream().map(word -> word.toUpperCase()).collect(Collectors.toList());
		System.out.println("processed : " + processBtrand);

	}

}
