package com.kodewala.oopspractice.override;

class PaymentSystem
{
	public void pay()
	{
		System.out.println("doing payment");
	}
}

class PhonePay extends PaymentSystem
{
	public void pay()
	{
		System.out.println("Doing payment by PhonePay");
	}
}

class GPay extends PaymentSystem
{
	public void pay()
	{
		System.out.println("Doing payment by Googlepay");
	}
}
public class PaymentApp {

	public static void main(String[] args) {
		
		PaymentSystem p1 = new PaymentSystem();
		p1.pay();
		System.out.println("---------------------");
		
		PhonePay p2 = new PhonePay();
		p2.pay();
		System.out.println("--------------------");
		
		GPay p3 = new GPay();
		p3.pay();
	}

}




class Car {
    public void refuel() {
        System.out.println("Car is refueling...");
    }
}

// Fuel Car
class FuelCar extends Car {
    @Override
    public void refuel() {
        System.out.println("Fuel Car is filling petrol/diesel...");
    }
}

// Electric Car (EV)
class EVCar extends Car {
    @Override
    public void refuel() {
        System.out.println("EV Car is charging battery...");
    }
}

public class Main {
    public static void main(String[] args) {

        Car c1 = new FuelCar();
        c1.refuel();   // FuelCar version

        Car c2 = new EVCar();
        c2.refuel();   // EVCar version
    }
}
